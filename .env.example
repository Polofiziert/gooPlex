PORT=3001
AI_PROVIDER=cursor-cli
CURSOR_MODEL=sonnet-4
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://localhost:8080
# SearXNG instance secret. Generate with: openssl rand -hex 32
# Wired into the container via docker-compose from slice 03 on (was hardcoded in settings.yml in slice 02).
SEARXNG_SECRET=replace-with-openssl-rand-hex-32
MAX_QUERIES=4
RANK_CANDIDATE_CAP=24
AI_TIMEOUT_MS=45000
CACHE_TTL_MS=600000
DEBUG_AI=0
